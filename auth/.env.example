# приложение
APP_ENV=local
SERVER_PORT=8080
JWT_SIGNING_KEY=local-dev-secret-change-me-local-dev-secret-change-me

# CORS
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Authorization,Content-Type

# переменные для подключения к PostgreSQL
POSTGRES_HOST=auth_postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=auth_db
POSTGRES_SSL_MODE=disable

# переменные для подключения к Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=admin
REDIS_DB=0

# переменные для подключения к Kafka
KAFKA_BROKERS=auth_kafka:9092

# переменные для подключения к Nats
NATS_HOST=nats
NATS_PORT=4222
NATS_USER=admin
NATS_PASSWORD=admin

# бизнес-константы (TTL, попытки, cooldown)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_LEN=32
REFRESH_SESSION_TTL=720h
CODE_MAX_ATTEMPTS=5
CODE_TTL=15m
CODE_RESEND_COOLDOWN=1m
CODE_RESEND_WINDOW=15m
CODE_RESEND_MAX_REQUESTS=5
PASSWORD_CHANGE_TOKEN_TTL=15m
PASSWORD_RESET_TOKEN_TTL=15m
EMAIL_CHANGE_TOKEN_TTL=15m

# url фронта для верификации cli
VERIFICATION_URL=http://localhost:5173/cli/login    