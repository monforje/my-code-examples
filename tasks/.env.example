# приложение
APP_ENV=local
SERVER_PORT=8080
JWT_SIGNING_KEY=local-dev-secret-change-me-local-dev-secret-change-me

# CORS
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Authorization,Content-Type

# PostgreSQL
POSTGRES_HOST=tasks_postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=tasks_db
POSTGRES_SSL_MODE=disable

# бизнес-константы
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_LEN=32

# Git Auth HTTP client
HTTP_CLIENT_GIT_TASKS_CLIENT_TOKEN=d7cDSzPleedFECuJbksoeRNdiKAZZjFmm_6GDGv1H-E
HTTP_CLIENT_GIT_TASKS_CLIENT_BASE_URL=http://taskrunner:8000

# Reports service token (validates POST /reports from notifications)
REPORTS_SERVICE_TOKEN=local-dev-reports-token
